#include <stdio.h>
#define MAX 5
int find_index (int atl [ ], int numf)
{

     int k;
     for (k=0; k< MAX; k++)
     {
     if (atl [k] == numf)
     return k;
     }
     return -5;
     }
     int main()
    {
